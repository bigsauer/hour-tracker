# Supabase (from project settings → API, or MCP get_project_url + get_publishable_keys)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# App sign-in password (not shown in UI — set the same password on your Supabase user)
VITE_AUTH_PASSWORD=choose-a-long-random-password
